{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jobcoach.core-schemas.json",
  "title": "JobCoach Core Schemas",
  "type": "object",
  "definitions": {
    "JobSpec": {
      "type": "object",
      "required": [
        "job_spec_id",
        "source",
        "role_title",
        "responsibilities",
        "requirements",
        "competency_weights",
        "extraction_confidence"
      ],
      "properties": {
        "job_spec_id": { "type": "string" },
        "source": {
          "type": "object",
          "required": ["type", "value", "captured_at"],
          "properties": {
            "type": { "type": "string", "enum": ["url", "text", "document_ref"] },
            "value": { "type": "string" },
            "captured_at": { "type": "string", "format": "date-time" }
          }
        },
        "company": { "type": "string" },
        "role_title": { "type": "string" },
        "seniority_level": { "type": "string" },
        "location": { "type": "string" },
        "employment_type": { "type": "string" },
        "responsibilities": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "requirements": {
          "type": "object",
          "required": ["required_skills", "preferred_skills"],
          "properties": {
            "required_skills": {
              "type": "array",
              "items": { "type": "string" }
            },
            "preferred_skills": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "competency_weights": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "evidence_spans": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "text", "confidence"],
            "properties": {
              "field": { "type": "string" },
              "text": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "extraction_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "version": { "type": "integer", "minimum": 1 }
      }
    },
    "CandidateProfile": {
      "type": "object",
      "required": ["candidate_id", "summary", "experience", "skills", "parse_confidence", "version"],
      "properties": {
        "candidate_id": { "type": "string" },
        "summary": { "type": "string" },
        "target_roles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "experience": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["company", "title", "start_date", "highlights"],
            "properties": {
              "company": { "type": "string" },
              "title": { "type": "string" },
              "start_date": { "type": "string", "format": "date" },
              "end_date": { "type": "string" },
              "highlights": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "skills": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "parse_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "storybank": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "story_id",
              "situation",
              "task",
              "action",
              "result",
              "competencies",
              "evidence_quality"
            ],
            "properties": {
              "story_id": { "type": "string" },
              "situation": { "type": "string" },
              "task": { "type": "string" },
              "action": { "type": "string" },
              "result": { "type": "string" },
              "metrics": {
                "type": "array",
                "items": { "type": "string" }
              },
              "competencies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "evidence_quality": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "version": { "type": "integer", "minimum": 1 }
      }
    },
    "InterviewSession": {
      "type": "object",
      "required": [
        "session_id",
        "job_spec_id",
        "candidate_id",
        "questions",
        "scores",
        "overall_score",
        "created_at"
      ],
      "properties": {
        "session_id": { "type": "string" },
        "job_spec_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "mode": { "type": "string", "enum": ["mock_interview", "drill", "negotiation"] },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["question_id", "text", "competency", "difficulty", "response", "score"],
            "properties": {
              "question_id": { "type": "string" },
              "text": { "type": "string" },
              "competency": { "type": "string" },
              "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
              "response": { "type": "string" },
              "follow_up_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "planner_metadata": {
                "type": "object",
                "required": ["source_competency", "ranking_position", "deterministic_confidence"],
                "properties": {
                  "source_competency": { "type": "string" },
                  "ranking_position": { "type": "integer", "minimum": 1 },
                  "deterministic_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "selection_reason": { "type": "string" },
                  "trigger_question_id": { "type": "string" },
                  "trigger_score": { "type": "number", "minimum": 0, "maximum": 100 },
                  "override_applied": { "type": "boolean" },
                  "override_reviewer_id": { "type": "string" },
                  "override_reason": { "type": "string" },
                  "override_trigger_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              },
              "score": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          }
        },
        "scores": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
        },
        "overall_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "root_cause_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "FeedbackReport": {
      "type": "object",
      "required": ["feedback_report_id", "session_id", "top_gaps", "action_plan", "overall_score", "generated_at"],
      "properties": {
        "feedback_report_id": { "type": "string" },
        "session_id": { "type": "string" },
        "top_gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gap", "severity", "root_cause", "evidence"],
            "properties": {
              "gap": { "type": "string" },
              "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
              "root_cause": { "type": "string" },
              "evidence": { "type": "string" }
            }
          }
        },
        "competency_scores": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
        },
        "overall_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "version": { "type": "integer", "minimum": 1 },
        "supersedes_feedback_report_id": { "type": "string" },
        "answer_rewrites": {
          "type": "array",
          "items": { "type": "string" }
        },
        "action_plan": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["day", "task", "success_metric"],
            "properties": {
              "day": { "type": "integer", "minimum": 1, "maximum": 30 },
              "task": { "type": "string" },
              "success_metric": { "type": "string" }
            }
          }
        },
        "trajectory_update": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    },
    "TrajectoryPlan": {
      "type": "object",
      "required": ["trajectory_plan_id", "candidate_id", "target_role", "milestones", "generated_at"],
      "properties": {
        "trajectory_plan_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "target_role": { "type": "string" },
        "horizon_months": { "type": "integer", "minimum": 1, "maximum": 24 },
        "role_readiness_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "target_date", "metric"],
            "properties": {
              "name": { "type": "string" },
              "target_date": { "type": "string", "format": "date" },
              "metric": { "type": "string" }
            }
          }
        },
        "weekly_plan": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["week", "actions"],
            "properties": {
              "week": { "type": "integer", "minimum": 1 },
              "actions": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "progress_summary": {
          "type": "object",
          "properties": {
            "history_counts": {
              "type": "object",
              "properties": {
                "interview_sessions": { "type": "integer", "minimum": 0 },
                "feedback_reports": { "type": "integer", "minimum": 0 },
                "snapshots": { "type": "integer", "minimum": 0 }
              }
            },
            "baseline": {
              "type": "object",
              "properties": {
                "timestamp": { "type": "string", "format": "date-time" },
                "source_type": { "type": "string" },
                "source_id": { "type": "string" },
                "overall_score": { "type": "number", "minimum": 0, "maximum": 100 }
              }
            },
            "current": {
              "type": "object",
              "properties": {
                "timestamp": { "type": "string", "format": "date-time" },
                "source_type": { "type": "string" },
                "source_id": { "type": "string" },
                "overall_score": { "type": "number", "minimum": 0, "maximum": 100 }
              }
            },
            "delta": {
              "type": "object",
              "properties": {
                "overall_score": { "type": "number", "minimum": -100, "maximum": 100 }
              }
            },
            "competency_trends": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "competency",
                  "baseline_score",
                  "current_score",
                  "delta_score",
                  "observation_count"
                ],
                "properties": {
                  "competency": { "type": "string" },
                  "baseline_score": { "type": "number", "minimum": 0, "maximum": 100 },
                  "current_score": { "type": "number", "minimum": 0, "maximum": 100 },
                  "delta_score": { "type": "number", "minimum": -100, "maximum": 100 },
                  "observation_count": { "type": "integer", "minimum": 0 }
                }
              }
            },
            "top_improving_competencies": {
              "type": "array",
              "items": { "type": "string" }
            },
            "top_risk_competencies": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
